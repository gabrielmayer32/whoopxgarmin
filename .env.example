# ── WHOOP ─────────────────────────────────────────────────────────────────────
# Create a free developer app at https://developer.whoop.com
# Set the redirect URI to: http://localhost:8000/whoop/callback
WHOOP_CLIENT_ID=your_whoop_client_id
WHOOP_CLIENT_SECRET=your_whoop_client_secret
WHOOP_REDIRECT_URI=http://localhost:8000/whoop/callback

# ── Garmin ────────────────────────────────────────────────────────────────────
# Your Garmin Connect login credentials
# Tokens are auto-stored via garth in ~/.garminconnect/
GARMIN_EMAIL=your_email@example.com
GARMIN_PASSWORD=your_password_here

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_random_string
DATABASE_URL=sqlite:///./health_data.db
